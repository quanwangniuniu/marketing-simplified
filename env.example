K6_TEST_USER_PASSWORD=testpassword123
K6_BASE_URL=http://localhost:8000
K6_FRONTEND_URL=http://localhost:3000

# InfluxDB Configuration (for K6 metrics storage)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=k6
INFLUXDB_BUCKET=k6
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=adminpassword

# IMPORTANT: INFLUXDB_TOKEN must be generated after InfluxDB is first started
# DO NOT commit real tokens to the repository. Use placeholder below.
# 
# To generate the token:
# 1. Start InfluxDB: docker-compose -f docker-compose.dev.yml up -d influxdb
# 2. Wait for InfluxDB to be ready (about 10-15 seconds)
# 3. Generate token: docker exec influxdb-k6 influx auth create --org k6 --all-access --description "K6 Load Testing Token"
# 4. Copy the token from the output and replace <generate-token-using-command-above> below
#
INFLUXDB_TOKEN=<generate-token-using-command-above>

K6_USE_CUSTOM_IMAGE=true
# ELK Stack Configuration
ELASTICSEARCH_HOST=http://localhost:9200
KIBANA_HOST=http://localhost:5601
LOG_RETENTION_DAYS=7

# Stripe Configuration
# Shared Test Keys for Development
STRIPE_SECRET_KEY=sk_test_... # The shared test key
STRIPE_PUBLISHABLE_KEY=pk_test_... # The shared test key
STRIPE_WEBHOOK_SECRET=whsec_... # Must generally be replaced by your local CLI secret. See backend/stripe_meta/README.md


# Zoom OAuth Configuration
# Create a General App (NOT Server-to-Server) at https://marketplace.zoom.us/develop/apps
# Add redirect URI: http://localhost/api/v1/zoom/callback/
# Required scopes: meeting:write:meeting, user:read:user
# Post-meeting sync (Celery): add meeting:read, report:read:admin or report:read, cloud_recording:read:admin,
# meeting_summary:read (exact names depend on Zoom Marketplace; reconnect after scope changes).
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URI=http://localhost/api/v1/zoom/callback/
# Webhooks: set Event notification URL to https://<host>/api/v1/zoom/webhook/ in Zoom Marketplace.
# Subscribe to P0: meeting.ended, recording.completed; P1: recording.transcript_completed (confirm name), meeting.summary_completed.
ZOOM_WEBHOOK_SECRET_TOKEN=

# AI Agent Related
DIFY_API_URL=...
DIFY_API_KEY=...
DIFY_CHAT_API_KEY=...
DIFY_MIRO_API_KEY=...
DIFY_COLUMN_DETECTION_API_KEY=...
DIFY_CRITERIA_API_KEY=...

# SLACK Related
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...
SLACK_SIGNING_SECRET=...
SLACK_REDIRECT_URI=...

# Email Configuration (for password reset emails)
# Fill in the SMTP credentials provided by your email service provider.
# Common providers: SendGrid, Mailgun, Resend, AWS SES, or any SMTP service.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=your-smtp-host
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Development only — prints emails to terminal, no real sending
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Shared secret for the platform-native cron endpoint that fires the daily
# Meta ads fan-out. Leave empty to disable the endpoint (it will always 401).
INTERNAL_CRON_SECRET=
